# KERI Foundation Plugin Configuration
# Copy this file to .env and fill in actual values.

# Development witness-hk endpoints used by the KF plugin provisioning UI.
KF_DEV_WITNESS_URL_1=http://127.0.0.1:5632
KF_DEV_BOOT_URL_1=http://127.0.0.1:5631
KF_DEV_REGION_1=local
KF_DEV_LABEL_1="Local Dev"

# Production endpoints for the KF plugin provisioning UI.
# Leave blank until the production witness service is available.
KF_PROD_WITNESS_URL_1=
KF_PROD_BOOT_URL_1=
KF_PROD_REGION_1=
KF_PROD_LABEL_1=
